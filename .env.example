# ─── Server ────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database ──────────────────────────────────────────
DB_URL=mongodb://localhost:27017/cartify
DB_URL_ONLINE=mongodb+srv://<user>:<password>@cluster.mongodb.net/cartify

# ─── Auth ──────────────────────────────────────────────
JWT_SECRET=replace_with_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ─── Email (Gmail App Password) ────────────────────────
EMAIL_SENDER=your_email@gmail.com
EMAIL_SENDER_PASSWORD=your_16_char_app_password

# ─── Cloudinary ────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── CORS ──────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── MQTT (Smart Return Boxes) ─────────────────────────
MQTT_BROKER_URL=mqtt://localhost:1883
# For authenticated brokers:
# MQTT_USERNAME=your_mqtt_user
# MQTT_PASSWORD=your_mqtt_password
# For TLS (production):
# MQTT_BROKER_URL=mqtts://broker.example.com:8883
# MQTT_CA_CERT_PATH=./certs/ca.crt
